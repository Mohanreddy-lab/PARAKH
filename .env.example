# ── LLM (default: local Ollama — no API key needed) ───────────────────────────
LLM_PROVIDER=ollama          # "ollama" (default) or "gemini"
PARAKH_MODEL=llama3.2        # any model pulled in Ollama: mistral:7b, llama3.2, etc.

# ── Optional: Gemini free tier fallback ───────────────────────────────────────
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AI...
# PARAKH_MODEL=gemini-1.5-flash

# ── Embedding (optional — default shown) ──────────────────────────────────────
PARAKH_EMBED_MODEL=all-MiniLM-L6-v2

# ── Pipeline sizes (optional) ─────────────────────────────────────────────────
PARAKH_RECALL_K=200          # candidates retrieved from FAISS
PARAKH_SCORE_N=50            # passed to LLM rerank
PARAKH_RERANK_N=50           # actually scored by the LLM

# ── Signal weights (auto-normalized, optional) ────────────────────────────────
PARAKH_W_EMBED=0.30
PARAKH_W_SKILL=0.40
PARAKH_W_SENIORITY=0.15
PARAKH_W_ACTIVITY=0.15

# ── LLM blend (optional) ──────────────────────────────────────────────────────
PARAKH_BLEND_COMPOSITE=0.40
PARAKH_BLEND_LLM=0.60
PARAKH_PROFILE_CHARS=900
PARAKH_LLM_RETRIES=2

# ── Hidden gem detection (optional) ───────────────────────────────────────────
PARAKH_HIDDEN_GEM_MIN_COMPOSITE=0.40
PARAKH_HIDDEN_GEM_MIN_RANK_JUMP=2
