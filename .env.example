# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Model (optional — default shown) ──────────────────────────────────────────
PARAKH_OPENAI_MODEL=gpt-4o

# ── Embedding (optional) ───────────────────────────────────────────────────────
PARAKH_EMBED_MODEL=all-MiniLM-L6-v2

# ── Pipeline sizes (optional) ─────────────────────────────────────────────────
PARAKH_RECALL_K=200          # candidates retrieved from FAISS
PARAKH_SCORE_N=50            # passed to LLM rerank
PARAKH_RERANK_N=50           # actually scored by GPT-4o

# ── Signal weights (auto-normalized, optional) ────────────────────────────────
PARAKH_W_EMBED=0.30
PARAKH_W_SKILL=0.40
PARAKH_W_SENIORITY=0.15
PARAKH_W_ACTIVITY=0.15

# ── LLM blend (optional) ──────────────────────────────────────────────────────
PARAKH_BLEND_COMPOSITE=0.40  # weight of Stage-3 composite in final blend
PARAKH_BLEND_LLM=0.60        # weight of GPT-4o score in final blend
PARAKH_PROFILE_CHARS=900     # max chars sent to GPT-4o per candidate
PARAKH_LLM_RETRIES=2         # retry attempts on API failure

# ── Hidden gem detection (optional) ───────────────────────────────────────────
PARAKH_HIDDEN_GEM_MIN_COMPOSITE=0.40
PARAKH_HIDDEN_GEM_MIN_RANK_JUMP=2
